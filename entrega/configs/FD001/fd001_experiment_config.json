{
  "dataset": "NASA C-MAPSS FD001",
  "task": "Remaining Useful Life regression",
  "scope": "FD001 only",
  "preprocessing": {
    "dropped_columns": [
      "setting_3",
      "sensor_1",
      "sensor_5",
      "sensor_10",
      "sensor_16",
      "sensor_18",
      "sensor_19"
    ],
    "rul_raw": "uncapped true RUL used for metrics",
    "rul_cap": 125,
    "training_target": "RUL capped at 125",
    "scaler": "StandardScaler fit only on training units"
  },
  "validation": {
    "split_policy": "complete engine units, never individual rows",
    "eval_size": 0.2,
    "random_state": 42,
    "cut_ruls": [20, 50, 80, 110, 140],
    "cutoff_rule": "cut_cycle = max_cycle - cut_rul; skip if cut_cycle < 1",
    "model_selection": "validation artificial cutoffs only; official test is not used for hyperparameter selection"
  },
  "representations": {
    "current_cycle": {
      "description": "one row at prediction cycle",
      "expected_outputs": [
        "results/FD001/fd001_current_cycle_metrics.csv",
        "figures/fd001/"
      ]
    },
    "temporal_w30": {
      "description": "last available 30-cycle window ending at prediction cycle",
      "window_size": 30,
      "window_statistics": [
        "last",
        "mean",
        "std",
        "min",
        "max",
        "delta",
        "slope"
      ],
      "expected_outputs": [
        "results/FD001/fd001_temporal_metrics.csv",
        "figures/fd001_temporal/"
      ]
    }
  },
  "metrics": [
    "mae",
    "rmse",
    "r2",
    "cmapss_score",
    "cmapss_score_mean",
    "dangerous_error_pct"
  ],
  "dangerous_error": {
    "definition": "prediction - RUL_raw > 20",
    "unit": "cycles"
  },
  "cmapss_asymmetric_score": {
    "error": "d = prediction - RUL_raw",
    "if_d_lt_0": "exp(-d / 13) - 1",
    "if_d_gte_0": "exp(d / 10) - 1"
  }
}
